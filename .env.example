# Copie este arquivo para ".env" e ajuste os valores para o seu ambiente.
# O .env NUNCA deve ser enviado para o controle de versão (já está no .gitignore).

# development | production
FLASK_ENV=development

# Gere uma chave aleatória forte para produção. Exemplo:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-esta-chave-em-producao

NOME_INSTITUICAO=Minha Instituição de Ensino
